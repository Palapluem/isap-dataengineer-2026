.venv/
__pycache__/
**/__pycache__/
*.py[cod]
*.egg-info/
src/*.egg-info/
.pytest_cache/
.pytest_tmp/
.ruff_cache/
.ipynb_checkpoints/
~$*.xlsx

# Local/editor/agent state must never be published.
.vscode/
.idea/
.codex/
.agent/
.agents/

# Secrets and local environment.
.env
.env.*
*.pem
*.key
*.secret

# Private/internal reference material.
references/

# Local authoring material that is not part of the submission.
assignment/ISAP_DATA_ENG_AGENT_PROMPT.md
docs/presentation_*.md
/*.pdf
/*_logo.png
/README_*.md

# Local helpers used while authoring the submission are not deliverables.
scripts/

# Local helpers and visual working files stay local; the public repository keeps runnable evidence.
presentation_assets/

data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/warehouse/*
!data/warehouse/.gitkeep

*.duckdb
*.duckdb.wal
*.log
